{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "experimentalServices": {
    "frontend": {
      "entrypoint": "frontend",
      "routePrefix": "/",
      "framework": "angular"
    },
    "backend": {
      "entrypoint": "backend/api/index.js",
      "routePrefix": "/api",
      "framework": "express",
      "maxDuration": 30
    }
  }
}
