PORT=5000
NODE_ENV=development

# MongoDB Atlas — create free cluster at https://www.mongodb.com/atlas
# Network access: 0.0.0.0/0 (needed for Vercel)
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/fletnix?retryWrites=true&w=majority

# JWT (min 32 characters each)
JWT_ACCESS_SECRET=your-access-secret-min-32-characters-long
JWT_REFRESH_SECRET=your-refresh-secret-min-32-characters-long
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Angular app origin (CORS + password reset links)
FRONTEND_URL=http://localhost:4200

# Email (optional — password reset)
# EMAIL_DEV_MODE=console
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM_EMAIL=noreply@fletnix.app
# SMTP_FROM_NAME=FletNix

# OAuth demo client (optional)
# OAUTH_DEMO_CLIENT_ID=fletnix-demo
# OAUTH_DEMO_CLIENT_SECRET=demo-secret-change-me
